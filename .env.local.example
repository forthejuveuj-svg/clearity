# Supabase - Get these from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# OpenAI - server-side key (recommended for deployments)
# Add this as a secret in your hosting provider (e.g. Vercel Environment Variables).
OPENAI_API_KEY=sk-your-openai-key-here
